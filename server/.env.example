# Server port (defaults to 5000 if not set)
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rank-pilot

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=your-jwt-secret

# OpenAI API key — used for AI-powered SEO analysis (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key

# Browserbase API key — used for headless browser scraping & Google rank checks (https://www.browserbase.com)
BROWSERBASE_API_KEY=bb_your-browserbase-api-key
